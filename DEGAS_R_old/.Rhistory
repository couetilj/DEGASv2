geom_boxplot(position=position_dodge()) +
geom_point(aes(color=PACSI_label), position=position_jitterdodge()) +
scale_color_manual(values = c("1" = "darkred", "0" = "gray")) + theme(axis.text.x = element_text(angle = 0, hjust = 1, face = "bold", size = 30),
text = element_text(face = "bold", size = 30),
plot.subtitle = element_text(face = "bold", size = 30),
plot.caption = element_text(face = "bold", size = 30))
ggplot1 <- ggplot1 +
ylim(0, 1.2) +
facet_wrap(~cellType, nrow = 2) +
ggsignif::geom_signif(
data=anno_df,
aes(xmin=group1, xmax=group2, annotations=p.adj, y_position=y_pos),
manual=TRUE, textsize = 10
) +
labs(x = "PACSI Label", y = "DEGAS Hazard", color = "PACSI Label")
ggsave(filename = paste0(results_save_dir, "/PACSI_box.pdf"), plot = ggplot1, width = 25, height = 10, units = "in")
}
sc_dataset <- read.csv2(paste0(root_dir, "/GSE138852_counts.csv"), header = TRUE, row.names = 1, sep = ",")
sc_meta <- read.csv2(paste0(root_dir, "/GSE138852_covariates.csv"), header = TRUE, row.names = 1, sep = ",")
which(colnames(sc_dataset) != rownames(sc_meta))
sc_process <- my_preprocessing(sc_dataset, sc_meta)
sc_dataset <- sc_process[[1]]
sc_meta <- sc_process[[2]]
# use SCTransform to preprocess
sc_dataset <- RunPCA(sc_dataset, assay = "SCT", verbose = FALSE)
run_seurat <- function (counts,  project = "PACSI", min.cells = 400, min.features = 0,    normalization.method = "LogNormalize", scale.factor = 10000, selection.method = "vst", dims_Neighbors = 1:40, dims_UMAP = 1:10, verbose = TRUE) {
# ZL: I add this line for creating subject
Obejct <- CreateSeuratObject(counts = counts, project = project, min.cells = min.cells, min.features = min.features)
Obejct <- Seurat::NormalizeData(object = Obejct, normalization.method = normalization.method,
scale.factor = scale.factor, verbose = verbose)
Obejct <- Seurat::FindVariableFeatures(object = Obejct, nfeatures = 3000,
selection.method = selection.method, verbose = verbose)
Obejct <- Seurat::ScaleData(object = Obejct, verbose = verbose)
Obejct <- Seurat::RunPCA(object = Obejct, features = VariableFeatures(Obejct),
verbose = verbose)
Obejct <- Seurat::FindNeighbors(object = Obejct, dims = dims_Neighbors,
verbose = verbose)
Obejct <- Seurat::RunUMAP(object = Obejct, dims = dims_UMAP,
verbose = verbose)
}
