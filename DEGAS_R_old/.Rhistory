which(is.na(bulk_dataset)) # check no missing data
ColMeta <- read.csv(paste0(root_dir, "/BM22_meta.csv"), header = TRUE, row.names = 1)
which(colnames(bulk_dataset) != rownames(ColMeta)) # check if disease attributes aligns with patient name
sc_meta <- data.frame(barcode = rownames(sc_meta), batchCond = sc_meta$oupSample.batchCond, cellType = sc_meta$oupSample.cellType)
for (disease_index in c("Braak", "CDR", "plaque")) {
