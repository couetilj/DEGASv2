theme(axis.text.x = element_text(face = "bold", size = 15),
axis.text.y = element_text(face = "bold", size = 15),
text = element_text(face = "bold", size = 15),
plot.subtitle = element_text(face = "bold", size = 15),
plot.caption = element_text(face = "bold", size = 15))
ggsave(paste0(results_save_dir, "/umap.pdf"), width = 10, height = 8, dpi = 300)
# plot of hazard prediction on meta data
PACSI_pred <- merge(results_df, sc_meta, by = "barcode")
PACSI_perc_df <- PACSI_pred %>% group_by(batchCond, cellType) %>% dplyr::count(Hazard) %>% mutate(Percentage = n / sum(n))
ggplot(PACSI_perc_df, aes(x = batchCond, fill = Hazard, y = Percentage)) +
geom_col() +
geom_text(aes(label = sprintf("%.1f%%", Percentage * 100)), position = position_fill(0.5), size = 4) +
facet_grid(.~cellType) +
scale_fill_manual(values = c("1" = "darkred", "0" = "gray")) +
labs(x = "Cell Type", y = "Count")  +
guides(fill=guide_legend(title="Hazard")) +
theme(axis.text.x = element_text(face = "bold"),
axis.text.y = element_text(face = "bold"),
text = element_text(face = "bold"),
plot.subtitle = element_text(face = "bold"),
plot.caption = element_text(face = "bold"))
ggsave(paste0(results_save_dir, "/Hazard.pdf"), width = 10, height = 8, dpi = 300)
# plot comparision
colnames(PACSI_pred) <- c("X", "cell.scores", "FDR", "p.value", "PACSI_label", "batchCond", "cellType")
DEGAS_pred <- read.csv2(paste0("/N/slate/zli8/Scissor/Grubman_MSBB/DEGAS/Grubman_MSBB_", disease_index, "_SDE_2024-04-18/results.csv"))
colnames(DEGAS_pred) <- c("X", "cellType", "DEGAS_hazard", "batchCond")
merge_df <- merge(PACSI_pred, DEGAS_pred, by = c("X", "cellType", "batchCond"))
