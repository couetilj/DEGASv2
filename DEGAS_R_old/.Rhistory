if (!file.exists(results_save_dir)) {
dir.create(results_save_dir)
}
results_df <- read.csv(paste0(results_save_dir, "/", disease_index, ".csv"))
colnames(results_df) <- c("barcode", "cell_scores", "p.value", "FDR", "Hazard")
results_df$Hazard <- as.character(results_df$Hazard)
# Visualization on Umap
umap_data <- Embeddings(sc_dataset, "umap")
# check if row name of umap simmilar to scissor pred
umap_df <- data.frame(UMAP_1 = umap_data[, 1], UMAP_2 = umap_data[, 2]) %>% mutate(barcode = rownames(umap_data))
umap_df <- merge(umap_df, results_df, by = "barcode")
ggplot(umap_df, aes(x = UMAP_1, y = UMAP_2, color = Hazard)) +
geom_point(alpha = 0.2) +
